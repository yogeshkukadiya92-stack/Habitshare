rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // KRAs
    match /kras/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && resource == null) || (isSignedIn() && resource.data.employee.id == request.auth.uid);
    }

    // Leaves
    match /leaves/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Expenses
    match /expenses/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Routine Tasks
    match /routineTasks/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Habits
    match /habits/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Attendance
    match /attendances/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Recruitment
    match /recruits/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Global Collections
    match /branches/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /holidays/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Roles management
    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      // Allow the initial master admin to set their own role
      allow write: if isOwner(userId) && request.auth.token.email == 'connect@luvfitnessworld.com';
    }
  }
}